# Server
PORT=6000

# PostgreSQL (used by docker-compose and local development)
# DB_HOST is only for local npm run — Docker uses the internal service name "db"
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=change_me_to_a_strong_password
DB_NAME=abk_db

# Schema sync (keep false in production — use scripts/fix-schema.sql)
DB_SYNC=false
DB_LOGGING=false

# CORS — comma-separated frontend URLs (Vercel + local)
# Defaults always include https://abou-khalil.vercel.app and localhost:3000
CORS_ORIGIN=https://abou-khalil.vercel.app,http://localhost:3000

# Default superAdmin (used by seed / password reset)
SEED_ADMIN_USERNAME=hassan
SEED_ADMIN_PASSWORD=P@ssw0rd
SEED_ADMIN_PHONE=0000000000

# Set to true only when you want seed-user to reset the admin password
SEED_ADMIN_RESET_PASSWORD=false
